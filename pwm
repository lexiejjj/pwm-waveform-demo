<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PWM → 正弦波 · 双周期演示</title>
    <style>
        * {
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, system-ui, sans-serif;
        }
        body {
            background: linear-gradient(145deg, #f0f2f5 0%, #e6e9f0 100%);
            min-height: 100vh;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .card {
            max-width: 1100px;
            width: 100%;
            background: rgba(255,255,255,0.75);
            backdrop-filter: blur(8px);
            border-radius: 42px;
            box-shadow: 0 20px 40px rgba(0,20,40,0.25), inset 2px 2px 6px #ffffffcc, inset -6px -6px 12px #b0b8c766;
            padding: 28px 30px 38px;
            border: 1px solid #ffffffcc;
        }
        h2 {
            margin: 0 0 8px 10px;
            font-weight: 500;
            color: #1e2b3c;
            letter-spacing: 0.3px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        h2 i {
            font-size: 1.4rem;
            color: #3a6ea5;
        }
        .wave-panel {
            background: #1a2632e0;
            border-radius: 32px;
            padding: 20px 20px 15px 20px;
            margin-bottom: 28px;
            box-shadow: inset 0 0 0 1px #5e6f8b, 0 8px 18px #00000030;
            backdrop-filter: blur(2px);
        }
        .canvas-container {
            background: #11161e;
            border-radius: 24px;
            padding: 15px 10px 5px 10px;
            box-shadow: inset 0 4px 8px #00000060;
        }
        canvas {
            display: block;
            width: 100%;
            height: auto;
            background: #0f131a;
            border-radius: 18px;
            margin: 0 auto;
            box-shadow: 0 2px 6px #00000080;
        }
        .wave-title {
            display: flex;
            justify-content: space-between;
            margin: 10px 12px 0 12px;
            color: #b7cdff;
            font-weight: 400;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-size: 0.9rem;
        }
        .controls-area {
            background: #eef2f8dd;
            border-radius: 40px;
            padding: 28px 30px;
            margin-top: 20px;
            backdrop-filter: blur(4px);
            border: 1px solid #ffffffb0;
            box-shadow: 0 12px 22px #0000001a, inset 2px 2px 10px #ffffff, inset -4px -4px 8px #bcc3d0;
        }
        .input-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 30px 50px;
            justify-content: center;
            margin-bottom: 30px;
        }
        .param-card {
            flex: 1 1 220px;
            background: #d9e0ec60;
            border-radius: 60px;
            padding: 18px 24px;
            backdrop-filter: blur(4px);
            box-shadow: inset 0 1px 4px #ffffff, 0 6px 12px #0000001a;
            border: 1px solid #ffffffd0;
        }
        .param-label {
            font-size: 1.2rem;
            font-weight: 600;
            color: #243856;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
        }
        .param-label span {
            background: #2f4b70;
            color: white;
            border-radius: 40px;
            padding: 5px 18px;
            font-size: 1rem;
            font-weight: 400;
        }
        .slider-container {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        input[type=range] {
            flex: 1;
            height: 8px;
            -webkit-appearance: none;
            background: linear-gradient(90deg, #2e5f8a, #8ab3d7);
            border-radius: 20px;
            box-shadow: inset 0 2px 5px #0a1a2e;
        }
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 22px;
            height: 22px;
            background: white;
            border-radius: 50%;
            box-shadow: 0 2px 8px #002a4e, 0 0 0 2px #aac9ff;
            cursor: pointer;
            transition: 0.1s;
            border: 1px solid #3a7bb5;
        }
        .num-input {
            width: 95px;
            padding: 12px 10px;
            border: none;
            background: #f0f6ff;
            border-radius: 40px;
            font-weight: 600;
            font-size: 1.2rem;
            text-align: center;
            color: #0f2a44;
            box-shadow: inset 2px 4px 8px #8f9eb0, inset -2px -2px 4px #ffffff, 0 2px 4px #00000010;
            border: 1px solid #ffffffd0;
        }
        .readout-panel {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-around;
            gap: 15px 25px;
            background: #c0d0e6a0;
            border-radius: 100px;
            padding: 18px 30px;
            margin-top: 10px;
            box-shadow: inset 0 1px 5px #eef4ff, 0 8px 14px #0000001a;
            backdrop-filter: blur(4px);
            font-weight: 600;
        }
        .readout-item {
            display: flex;
            align-items: baseline;
            gap: 8px;
            font-size: 1.2rem;
            color: #16273e;
        }
        .readout-item .tag {
            background: #2e4c70;
            color: white;
            padding: 6px 18px;
            border-radius: 50px;
            font-size: 1rem;
            letter-spacing: 0.5px;
        }
        .readout-item .value {
            font-family: 'JetBrains Mono', 'Fira Code', monospace;
            font-size: 1.8rem;
            font-weight: 650;
            color: #003153;
            min-width: 90px;
            text-align: right;
        }
        .unit {
            font-size: 1rem;
            color: #1e3c5e;
            font-weight: 400;
        }
        .footnote {
            text-align: center;
            color: #4a607a;
            margin-top: 25px;
            font-style: italic;
            border-top: 1px dashed #9fb1ca;
            padding-top: 16px;
        }
        button.ghost {
            background: transparent;
            border: 2px solid #3d6184;
            color: #1f3a5c;
            padding: 10px 30px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: 0.2s;
            cursor: pointer;
            margin-left: 20px;
        }
        button.ghost:hover {
            background: #3d6184;
            color: white;
        }
        .flex-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
    </style>
</head>
<body>
    <div class="card">
        <h2>
            <i>⚡</i> PWM 生成正弦波 (双周期) <i>🌊</i>
        </h2>
        <div class="wave-panel">
            <div class="wave-title">
                <span>◾ PWM 方波 (两个完整周期)</span>
                <span>⏥ 高电平时间 = CCR</span>
            </div>
            <div class="canvas-container">
                <canvas id="pwmCanvas" width="900" height="140"></canvas>
            </div>
        </div>
        <div class="wave-panel">
            <div class="wave-title">
                <span>◾ 正弦波 (RC滤波模拟, 两个周期)</span>
                <span>🔄 基频同PWM</span>
            </div>
            <div class="canvas-container">
                <canvas id="sineCanvas" width="900" height="140"></canvas>
            </div>
        </div>
        <div class="controls-area">
            <div class="input-grid">
                <div class="param-card">
                    <div class="param-label">
                        ⏲️ ARR (自动重载) <span>周期计数</span>
                    </div>
                    <div class="slider-container">
                        <input type="range" id="arrSlider" min="20" max="400" value="200" step="1">
                        <input type="number" id="arrInput" class="num-input" value="200" min="20" max="400" step="1">
                    </div>
                    <div style="font-size:0.9rem; margin-top: 12px; color:#345075;">↑ 决定PWM周期(计数值)</div>
                </div>
                <div class="param-card">
                    <div class="param-label">
                        🔲 CCR (比较值) <span>占空比调节</span>
                    </div>
                    <div class="slider-container">
                        <input type="range" id="ccrSlider" min="0" max="200" value="100" step="1">
                        <input type="number" id="ccrInput" class="num-input" value="100" min="0" max="200" step="1">
                    </div>
                    <div style="font-size:0.9rem; margin-top: 12px; color:#345075;">0 ~ ARR (实际钳位)</div>
                </div>
            </div>
            <div class="readout-panel">
                <div class="readout-item">
                    <span class="tag">占空比</span>
                    <span class="value" id="dutyValue">50.0</span>
                    <span class="unit">%</span>
                </div>
                <div class="readout-item">
                    <span class="tag">周期</span>
                    <span class="value" id="periodValue">2.00</span>
                    <span class="unit">ms</span>
                </div>
                <div class="readout-item">
                    <span class="tag">频率</span>
                    <span class="value" id="freqValue">500</span>
                    <span class="unit">Hz</span>
                </div>
            </div>
            <div class="flex-row" style="margin-top: 25px;">
                <div style="color: #2b4b75; font-size: 0.95rem;">✱ 假设时基时钟 = 100 kHz (10µs/计数) → 方便计算</div>
                <button class="ghost" id="refreshBtn">⟳ 重新绘制</button>
            </div>
        </div>
        <div class="footnote">
            ⬇ 每次修改数值或滑动条都会实时更新波形 (两个完整PWM周期)。正弦波是理想一阶低通滤波效果(相位滞后, 幅度衰减)
        </div>
    </div>
    <script>
        (function() {
            const pwmCanvas = document.getElementById('pwmCanvas');
            const sineCanvas = document.getElementById('sineCanvas');
            const ctxPWM = pwmCanvas.getContext('2d');
            const ctxSine = sineCanvas.getContext('2d');
            const arrSlider = document.getElementById('arrSlider');
            const arrInput = document.getElementById('arrInput');
            const ccrSlider = document.getElementById('ccrSlider');
            const ccrInput = document.getElementById('ccrInput');
            const dutySpan = document.getElementById('dutyValue');
            const periodSpan = document.getElementById('periodValue');
            const freqSpan = document.getElementById('freqValue');
            const CLOCK_PERIOD_US = 10;
            const CLOCK_FREQ_HZ = 100000;
            function clampCcr() {
                let arr = parseInt(arrInput.value, 10);
                let ccr = parseInt(ccrInput.value, 10);
                if (isNaN(arr) || arr < 20) arr = 20;
                if (isNaN(ccr)) ccr = 0;
                const clampedCcr = Math.min(ccr, arr);
                if (clampedCcr !== ccr) {
                    ccrInput.value = clampedCcr;
                    ccrSlider.value = clampedCcr;
                }
                return { arr, ccr: clampedCcr };
            }
            function syncInputs(source) {
                let arr, ccr;
                if (source === 'arr') {
                    arr = parseInt(arrInput.value, 10);
                    if (isNaN(arr) || arr < 20) arr = 20;
                    arrInput.value = arr;
                    arrSlider.value = arr;
                    ccr = parseInt(ccrInput.value, 10);
                    if (isNaN(ccr)) ccr = 0;
                    if (ccr > arr) {
                        ccr = arr;
                        ccrInput.value = ccr;
                        ccrSlider.value = ccr;
                    }
                } else if (source === 'ccr') {
                    ccr = parseInt(ccrInput.value, 10);
                    if (isNaN(ccr) || ccr < 0) ccr = 0;
                    arr = parseInt(arrInput.value, 10);
                    if (isNaN(arr) || arr < 20) arr = 20;
                    if (ccr > arr) {
                        ccr = arr;
                    }
                    ccrInput.value = ccr;
                    ccrSlider.value = ccr;
                }
                return { arr, ccr };
            }
            function updateCalculations(arr, ccr) {
                const duty = (arr > 0) ? (ccr / arr) * 100 : 0;
                const periodUs = arr * CLOCK_PERIOD_US;
                const periodMs = periodUs / 1000;
                const freqHz = (periodUs > 0) ? (1e6 / periodUs) : 0;
                dutySpan.textContent = duty.toFixed(2);
                periodSpan.textContent = periodMs.toFixed(3);
                freqSpan.textContent = Math.round(freqHz);
            }
            function drawWaveforms(arr, ccr) {
                const width = 900;
                const heightPWM = 140;
                const heightSine = 140;
                ctxPWM.clearRect(0, 0, width, heightPWM);
                ctxSine.clearRect(0, 0, width, heightSine);
                ctxPWM.fillStyle = '#0f131a';
                ctxPWM.fillRect(0, 0, width, heightPWM);
                ctxSine.fillStyle = '#0f131a';
                ctxSine.fillRect(0, 0, width, heightSine);
                ctxPWM.strokeStyle = '#2d405b';
                ctxPWM.lineWidth = 0.8;
                ctxPWM.setLineDash([3, 6]);
                for (let y = 30; y < heightPWM; y += 30) {
                    ctxPWM.beginPath();
                    ctxPWM.moveTo(0, y);
                    ctxPWM.lineTo(width, y);
                    ctxPWM.strokeStyle = '#2f4160';
                    ctxPWM.stroke();
                }
                ctxSine.strokeStyle = '#2d405b';
                ctxSine.setLineDash([3, 6]);
                for (let y = 30; y < heightSine; y += 30) {
                    ctxSine.beginPath();
                    ctxSine.moveTo(0, y);
                    ctxSine.lineTo(width, y);
                    ctxSine.strokeStyle = '#2f4160';
                    ctxSine.stroke();
                }
                ctxPWM.setLineDash([]);
                ctxSine.setLineDash([]);
                const totalPeriods = 2;
                const totalSamples = 600;
                const dx = width / totalSamples;
                const pwmPoints = [];
                for (let i = 0; i <= totalSamples; i++) {
                    const t = i / totalSamples;
                    const periodIndex = Math.floor(t * totalPeriods);
                    const phaseInPeriod = (t * totalPeriods) - periodIndex;
                    const high = phaseInPeriod < (ccr / arr);
                    const yVal = high ? 30 : 110;
                    pwmPoints.push({ x: i * dx, y: yVal });
                }
                ctxPWM.beginPath();
                ctxPWM.strokeStyle = '#ffd966';
                ctxPWM.lineWidth = 3;
                ctxPWM.setLineDash([]);
                for (let i = 0; i < pwmPoints.length - 1; i++) {
                    const p1 = pwmPoints[i];
                    const p2 = pwmPoints[i+1];
                    ctxPWM.beginPath();
                    ctxPWM.moveTo(p1.x, p1.y);
                    ctxPWM.lineTo(p2.x, p1.y);
                    ctxPWM.lineTo(p2.x, p2.y);
                    ctxPWM.strokeStyle = '#ffc107';
                    ctxPWM.stroke();
                }
                ctxPWM.beginPath();
                ctxPWM.moveTo(pwmPoints[0].x, pwmPoints[0].y);
                for (let i = 1; i < pwmPoints.length; i++) {
                    ctxPWM.lineTo(pwmPoints[i].x, pwmPoints[i].y);
                }
                ctxPWM.strokeStyle = '#ffaa33';
                ctxPWM.lineWidth = 2.2;
                ctxPWM.stroke();
                const dutyRatio = ccr / arr;
                const fundamentalAmp = (4 / Math.PI) * Math.sin(Math.PI * dutyRatio);
                const phaseShift = -Math.PI/4;
                const sinPoints = [];
                const midY = heightSine / 2;
                const ampScale = 45;
                for (let i = 0; i <= totalSamples; i++) {
                    const t = i / totalSamples;
                    const theta = t * 4 * Math.PI;
                    let value = fundamentalAmp * Math.sin(theta + phaseShift);
                    value += 0.18 * (1/3) * (4/Math.PI) * Math.sin(3*Math.PI*dutyRatio) * Math.sin(3*theta + phaseShift*2);
                    const norm = Math.max(-1, Math.min(1, value * 0.9));
                    const y = midY - norm * ampScale;
                    sinPoints.push({ x: i * dx, y: y });
                }
                ctxSine.beginPath();
                ctxSine.strokeStyle = '#80deea';
                ctxSine.lineWidth = 3.2;
                ctxSine.setLineDash([]);
                ctxSine.moveTo(sinPoints[0].x, sinPoints[0].y);
                for (let i = 1; i < sinPoints.length; i++) {
                    ctxSine.lineTo(sinPoints[i].x, sinPoints[i].y);
                }
                ctxSine.strokeStyle = '#4fc3ff';
                ctxSine.shadowColor = '#00b8ff';
                ctxSine.shadowBlur = 12;
                ctxSine.stroke();
                ctxSine.shadowColor = 'transparent';
                ctxSine.beginPath();
                ctxSine.strokeStyle = '#406080';
                ctxSine.lineWidth = 1;
                ctxSine.setLineDash([5, 5]);
                ctxSine.moveTo(0, heightSine/2);
                ctxSine.lineTo(width, heightSine/2);
                ctxSine.stroke();
                ctxPWM.setLineDash([]);
                ctxSine.setLineDash([]);
            }
            function updateAll(source) {
                const { arr, ccr } = syncInputs(source);
                const finalCcr = Math.min(ccr, arr);
                if (finalCcr !== ccr) {
                    ccrInput.value = finalCcr;
                    ccrSlider.value = finalCcr;
                }
                updateCalculations(arr, finalCcr);
                drawWaveforms(arr, finalCcr);
            }
            arrSlider.addEventListener('input', function() {
                arrInput.value = arrSlider.value;
                updateAll('arr');
            });
            arrInput.addEventListener('input', function() {
                let val = parseInt(arrInput.value, 10);
                if (isNaN(val) || val < 20) val = 20;
                arrInput.value = val;
                arrSlider.value = val;
                updateAll('arr');
            });
            ccrSlider.addEventListener('input', function() {
                ccrInput.value = ccrSlider.value;
                updateAll('ccr');
            });
            ccrInput.addEventListener('input', function() {
                let val = parseInt(ccrInput.value, 10);
                if (isNaN(val) || val < 0) val = 0;
                ccrInput.value = val;
                ccrSlider.value = val;
                updateAll('ccr');
            });
            document.getElementById('refreshBtn').addEventListener('click', function() {
                const arr = parseInt(arrInput.value, 10);
                let ccr = parseInt(ccrInput.value, 10);
                if (ccr > arr) {
                    ccr = arr;
                    ccrInput.value = ccr;
                    ccrSlider.value = ccr;
                }
                updateAll('manual');
            });
            (function init() {
                arrSlider.value = 200;
                arrInput.value = 200;
                ccrSlider.value = 100;
                ccrInput.value = 100;
                updateAll('init');
            })();
        })();
    </script>
</body>
</html>
